# ─── AI Provider ──────────────────────────────────────────
# Which AI provider to use: openai | gemini | ollama
AI_PROVIDER=gemini

# OpenAI
OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY
OPENAI_MODEL=gpt-4o-mini

# Gemini
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY
GEMINI_MODEL=gemini-1.5-flash

# Ollama (local)
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
OLLAMA_MODEL=llama2
# Set to true if OLLAMA_ENDPOINT points to /api/chat
OLLAMA_USE_CHAT_API=false

# ─── AI Behaviour Tuning ──────────────────────────────────
# Maximum tokens the AI model returns per response
AI_MAX_TOKENS=1500
# Number of past messages included as context in each AI call
CHAT_HISTORY_LIMIT=20