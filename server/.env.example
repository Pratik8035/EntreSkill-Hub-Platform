# ============================================================
# EntreSkill Hub - Server Environment Variables
# ============================================================
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.

# ─── Server ───────────────────────────────────────────────
# The port the Express server listens on.
PORT=5000

# Deployment mode: development | production | test
# Controls logging verbosity, cookie security flags, and error detail exposure.
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────
# Full MongoDB Atlas connection string. Include username, password, and cluster host.
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority
# SECURITY: Rotate this credential immediately if it is ever leaked.
MONGO_URI=mongodb+srv://pratik:pratik123@cluster0.foq4lkq.mongodb.net/entreskill?retryWrites=true&w=majority

# ─── JWT Secrets ──────────────────────────────────────────
# Secret used to sign short-lived ACCESS tokens (valid: 15 minutes).
# Use a strong 64-character random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_64_CHAR_RANDOM_STRING

# Secret used to sign long-lived REFRESH tokens (valid: 7 days).
# Must be DIFFERENT from JWT_SECRET to prevent refresh tokens from being
# used as access tokens and vice versa.
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_64_CHAR_RANDOM_STRING

# ─── CORS ─────────────────────────────────────────────────
# The origin of the frontend client. Only requests from this origin will be
# allowed by the CORS middleware. Use a comma-separated list for multiple origins.
# Example for Vercel: https://entreskillhub.vercel.app
CLIENT_URL=http://localhost:5173

# ─── AI Provider ──────────────────────────────────────────
# Which AI provider to use: openai | gemini | ollama
AI_PROVIDER=openai

# OpenAI credentials
# Generate a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY
# Recommended: gpt-4o-mini (fast + cheap), gpt-4o (higher quality)
OPENAI_MODEL=gpt-4o-mini

# Google Gemini credentials
# Generate a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY
# Recommended: gemini-1.5-flash (fast), gemini-1.5-pro (higher quality)
GEMINI_MODEL=gemini-1.5-flash

# Ollama (local self-hosted model)
# Set OLLAMA_ENDPOINT to your local Ollama server URL.
# Use /api/generate for single-prompt mode (default).
# Use /api/chat and set OLLAMA_USE_CHAT_API=true for native messages[] support.
OLLAMA_ENDPOINT=http://localhost:11434/api/generate
OLLAMA_MODEL=llama2
OLLAMA_USE_CHAT_API=false

# ─── AI Behaviour Tuning ──────────────────────────────────
# Maximum number of tokens the AI model returns per response.
# 1500 is recommended for detailed entrepreneurship advice.
AI_MAX_TOKENS=1500

# Number of past chat messages included as conversation context in each AI call.
# Higher = more context (better coherence), slightly higher latency.
CHAT_HISTORY_LIMIT=20
